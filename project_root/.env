# deploy
DEPLOY='LOCAL'

# replicas
DEFAULT_REPLICAS=1
MESSAGE_CONSUMER_REPLICAS=1
DLX_CONSUMER_REPLICAS=1
BACKEND_REPLICAS=1

# nginx
NGINX_HTTP_PORT=3000
NGINX_TCP_PORT=5672

# postgres
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=postgres_db
POSTGRES_DB_TEST=postgres_db_test
PGPORT=5432
POSTGRES_STORAGE=../blob_store/postgres 

# minio
S3_ACCESS_KEY=s3_access_key
S3_SECRET_KEY=s3_secret_key
S3_BUCKET=vvs-bucket
S3_SECURE_CONNECTION=false
MINIO_ROOT_USER=${S3_ACCESS_KEY}
MINIO_ROOT_PASSWORD=${S3_SECRET_KEY}
MINIO_API_PORT=9000
MINIO_UI_PORT=9001
MINIO_STORAGE=../blob_store/data
S3_URL=minio:${MINIO_API_PORT}

# dagster webserver 
DAGSTER_WEBSERVER_PORT=7862

# dagster code server
DAGSTER_CODE_SERVER_PORT=4000

# redis
REDIS_HOST=redis # do not change, determined by docker service name
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_MESSAGE_TTL=3600
REDIS_DB=0
REDIS_POLL_INTERVAL=1

# RabbitMQ
RABBITMQ_HOST=rabbitmq # do not change, determined by docker service name
RABBITMQ_PORT=5672 # do not change - currently hardcoded
RABBITMQ_DEFAULT_USER=rabbitmq_user
RABBITMQ_DEFAULT_PASS=rabbitmq_password
RABBITMQ_EXCHANGE_NAME=vvs_exchange
RABBITMQ_RESPONSE_QUEUE_NAME='vvs_response_queue'
RABBITMQ_ALT_QUEUE_NAME='vvs_alt_queue'
RABBITMQ_DLQ_NAME='vvs_dlx'
RABBITMQ_DEFAULT_MESSAGE_EXP=86400000 # default 24 hours

# backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=7861
BACKEND_WORKERS=1
BACKEND_API_STR='/api/v1'


### plugin env vars

# plugin replicas
RDKIT_PLUGIN_REPLICAS=1
PLUGIN_INTEGRATION_SERVER_REPLICAS=1

# plugin integration server
PLUGIN_INTEGRATION_SERVER_HOST=0.0.0.0
PLUGIN_INTEGRATION_SERVER_PORT=7863
PLUGIN_INTEGRATION_SERVER_WORKERS=1

# rdkit
RDKIT_CONCURRENCY=64

# qdrant
QDRANT__SERVICE__HTTP_PORT=7333
QDRANT__SERVICE__GRPC_PORT=7334
QDRANT_STORAGE_DIR=../blob_store/qdrant
QDRANT_SNAPSHOT_DIR=../blob_store/qdrant_snapshots
QDRANT__STORAGE__SNAPSHOTS_PATH=./qdrant_snapshots
QDRANT__TELEMETRY_DISABLED=true

# qdrant performance
QDRANT__SERVICE__MAX_REQUEST_SIZE_MB=32
# QDRANT_UPSERT_BATCH_SIZE=32
# QDRANT_UPSERT_CONCURRENCY=12
QDRANT_QUERY_CONCURRENCY=32
QDRANT_QUERY_BATCH_SIZE=256
QDRANT_QUERY_TIMEOUT=45
QDRANT_QUERY_MAX_RETRIES=3

# triton
TRITON_DEVICE_ID=1
TRITON_REQUEST_CONCURRENCY=24
TRITON_HOST=0.0.0.0
TRITON_HTTP_PORT=7864
TRITON_METRICS_PORT=7865
TRITON_EMBED_BATCH_SIZE=1024
TRITON_MAPPER_BATCH_SIZE=1024
TRITON_MAX_QUEUE_DELAY=5000 # 5 ms max delay


# TEI
TEI_DEVICE_ID=0
TEI_REQUEST_CONCURRENCY=24
TEI_MODEL_ID=entropy/roberta_zinc_480m
TEI_DISTANCE_METRIC=Cosine # embedding distance metric, one of Cosine, Euclid, Dot
TEI_NORMALIZE=false # if embedding should be normalize
TEI_TRUNCATE=false # if input should be truncated
TEI_TRUNCATION_DIRECTION=Right # truncation direction
# TEI_REVISION=
# TEI_TOKENIZATION_WORKERS=
TEI_DTYPE=float16 # float16, float32
TEI_POOLING=mean # cls, mean, splade, last-token
# TEI_MAX_CONCURRENT_REQUESTS=
# TEI_MAX_BATCH_TOKENS=
# TEI_MAX_BATCH_REQUESTS=
TEI_MAX_CLIENT_BATCH_SIZE=512
# TEI_HF_API_TOKEN=
# TEI_HOSTNAME=
TEI_PORT=3100
TEI_HUGGINGFACE_HUB_CACHE=/data
# TEI_UDS_PATH=
# TEI_PAYLOAD_LIMIT=
# TEI_API_KEY=
# TEI_JSON_OUTPUT=
# TEI_OTLP_ENDPOINT=
# TEI_CORS_ALLOW_ORIGIN=


### test env vars 

# test generic
TEST_EMBEDDING_SIZE=32
TEST_NUM_PARENTS=2
TEST_BATCH_SIZE=5

# test server
TEST_SERVER_HOST=0.0.0.0
TEST_SERVER_PORT=7800

# test queue
TEST_CONSUMER_WORKERS=1
