# deploy
DEPLOY='LOCAL'

# replicas
DEFAULT_REPLICAS=1
MESSAGE_CONSUMER_REPLICAS=1
DLX_CONSUMER_REPLICAS=1
BACKEND_REPLICAS=1
RDKIT_PLUGIN_REPLICAS=1

# nginx
NGINX_HTTP_PORT=3000
NGINX_TCP_PORT=5672

#postgres
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=postgres_db
PGPORT=5432

#dagster generic
DAGSTER_POSTGRES_USER=${POSTGRES_USER}
DAGSTER_POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
DAGSTER_POSTGRES_DB=${POSTGRES_DB}

# dagster webserver 
DAGSTER_WEBSERVER_PORT=7862

# dagster code server
DAGSTER_CODE_SERVER_PORT=4000

# redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_MESSAGE_TTL=3600
REDIS_DB=0
REDIS_POLL_INTERVAL=1

# RabbitMQ
RABBITMQ_PORT=5672 # do not change
RABBITMQ_DEFAULT_USER=rabbitmq_user
RABBITMQ_DEFAULT_PASS=rabbitmq_password
RABBITMQ_EXCHANGE_NAME=vvs_exchange
RABBITMQ_RESPONSE_QUEUE_NAME='vvs_response_queue'
RABBITMQ_ALT_QUEUE_NAME='vvs_alt_queue'
RABBITMQ_DLQ_NAME='vvs_dlx'
RABBITMQ_DEFAULT_MESSAGE_EXP=86400000 # default 24 hours

# backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=7861
BACKEND_WORKERS=1

# test generic
TEST_EMBEDDING_SIZE=32
TEST_NUM_PARENTS=2

# test server
TEST_SERVER_HOST=0.0.0.0
TEST_SERVER_PORT=7800

# test queue
TEST_CONSUMER_WORKERS=1
